APP_NAME="TSEYOR Canva"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Poner a true para servir fuentes locales a través de una ruta dedicada (útil para php artisan serve)
DESIGNER_SERVE_FONTS_ROUTE=true
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=tseyor_canva
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

DESIGNER_IMAGE_MAX_WIDTH=2400
DESIGNER_IMAGE_MAX_HEIGHT=2400
DESIGNER_IMAGE_JPEG_QUALITY=95
DESIGNER_IMAGE_WEBP_QUALITY=95

JWT_SECRET=
JWT_TTL=10080

PORTAL_LOGIN_URL=https://tseyor.org/tseyor-canva
PORTAL_LOGIN_CALLBACK_PARAMETER=from

QUEUE_CONNECTION=database
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

DEPLOY_ENDPOINT=
DEPLOY_TOKEN=
DEPLOY_VERIFY_SSL=true
DEPLOY_TIMEOUT=1800
DEPLOY_ROUTE_ENABLED=true
