# Smart Import Calibration Pipeline — Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: Your OpenRouter API key
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenRouter API base URL (default: https://openrouter.ai/api/v1)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Default vision model for image → SceneGraph analysis
# Fast/cheap: google/gemini-2.5-flash
# Premium:    anthropic/claude-sonnet-4.5
DEFAULT_VISION_MODEL=google/gemini-2.5-flash

# Default compiler model for SceneGraph → .tc refinement (if not using deterministic compiler)
DEFAULT_COMPILER_MODEL=google/gemini-2.5-flash-lite

# Judge model for evaluating import quality
# Default:   google/gemini-2.5-pro
# Premium:   anthropic/claude-sonnet-4.5
# Fast:      google/gemini-2.5-flash
JUDGE_MODEL=google/gemini-2.5-pro
